{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/slack_ingest.py": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "query", "key": "tab", "value": "news" }],
      "destination": "/news.html",
      "permanent": false
    }
  ]
}
