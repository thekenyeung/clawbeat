{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/slack_ingest.py": {
      "maxDuration": 30
    },
    "api/news_permalink.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "openclaw.clawbeat.co" }],
      "destination": "/openclaw/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "openclaw.clawbeat.co" }],
      "destination": "/openclaw/:path*"
    },
    { "source": "/news/:date/:slug", "destination": "/api/news_permalink?date=:date&slug=:slug" }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "query", "key": "tab", "value": "news" }],
      "destination": "/news.html",
      "permanent": false
    }
  ]
}
